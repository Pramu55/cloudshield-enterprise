generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Environment {
  dev
  staging
  prod
  security
  shared
  sandbox
}

enum AwsAccountStatus {
  NOT_CONFIGURED
  CONNECTED
  AUTH_FAILED
  PERMISSION_DENIED
  PARTIAL_SCAN
  RATE_LIMITED
  FAILED
}

enum AwsConnectionStatus {
  NOT_CONFIGURED
  READY_FOR_VALIDATION
  VALIDATION_NOT_IMPLEMENTED
  VALIDATION_SUCCEEDED
  VALIDATION_FAILED
  CONNECTED_DEMO_ONLY
  AUTH_FAILED
  PERMISSION_DENIED
  DISABLED
}

enum FindingSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  INFO
}

enum RiskStatus {
  OPEN
  ACKNOWLEDGED
  ASSIGNED
  REMEDIATION_PLANNED
  ACCEPTED_RISK
  RISK_ACCEPTED
  FALSE_POSITIVE
  RESOLVED
  ARCHIVED
  REOPENED
}

enum RiskPriority {
  P0
  P1
  P2
  P3
  P4
}

enum ComplianceStatus {
  PASS
  FAIL
  WARNING
  NEEDS_REVIEW
  NOT_APPLICABLE
  NOT_EVALUATED
}

enum AccountCriticality {
  LOW
  MEDIUM
  HIGH
  MISSION_CRITICAL
}

enum ScanRunStatus {
  REQUESTED
  QUEUED
  RUNNING
  STARTED
  PARTIALLY_SUCCEEDED
  SUCCEEDED
  COMPLETED
  CANCELLED
  BLOCKED
  BLOCKED_DISABLED
  NOT_CONFIGURED
  AUTH_FAILED
  PERMISSION_DENIED
  PARTIAL_SCAN
  RATE_LIMITED
  FAILED
}

enum ReportExportStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

enum RemediationRiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RemediationActionType {
  NETWORK_EXPOSURE_REVIEW
  STORAGE_REVIEW
  IAM_REVIEW
  TAGGING_GOVERNANCE
  COMPLIANCE_EVIDENCE
  COST_GOVERNANCE
  MANUAL_REVIEW
}

enum RemediationImplementationMode {
  MANUAL
  AWS_CLI_REVIEW
  TERRAFORM_REVIEW
  FUTURE_GOVERNED_EXECUTION
}

enum RemediationApprovalStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  READY_FOR_EXECUTION
}

enum RemediationExecutionStatus {
  DRAFT
  EXECUTION_BLOCKED
  READY_FOR_EXECUTION
  COMPLETED_MANUALLY
}

enum MutationOutcome {
  NOT_ATTEMPTED
  ATTEMPTED
  CONFIRMED_SUCCEEDED
  CONFIRMED_FAILED
  OUTCOME_UNKNOWN
  MANUAL_REVIEW_REQUIRED
}

enum MutationReconciliationStatus {
  NOT_REQUIRED
  PENDING
  IN_PROGRESS
  RESOLVED
  MANUAL_REVIEW_REQUIRED
  FAILED_RETRYABLE
}

enum ApprovalRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum AutomationAssessmentStatus {
  CREATED
  CHECKING_CREDENTIALS
  VALIDATING_IDENTITY
  INVENTORY_BLOCKED
  INVENTORY_RUNNING
  INVENTORY_COMPLETED
  ANALYZING_SECURITY
  ANALYZING_COST
  MAPPING_COMPLIANCE
  GENERATING_REMEDIATION_PLANS
  GENERATING_REPORT
  COMPLETED
  FAILED
  BLOCKED_DISABLED
}

enum AutomationAssessmentMode {
  EVALUATION
  AWS_STS_ONLY
  AWS_READONLY_SCAN
}

enum DataSourceClassification {
  SAMPLE
  AWS_SYNC
  RULE_ENGINE
  MANUAL
  IMPORT
  SYSTEM
}

enum SavedViewWorkspace {
  INVENTORY
  SECURITY_FINDINGS
  COST_FINDINGS
  COMPLIANCE_RESULTS
  RISKS
  SCANS
  OPERATIONS
}

enum NotificationSeverity {
  INFO
  WARNING
  CRITICAL
}

enum UserStatus {
  ACTIVE
  DISABLED
}

model User {
  id                String       @id @default(cuid())
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email             String
  emailNormalized   String?      @unique
  name              String?
  passwordHash      String?
  status            UserStatus   @default(ACTIVE)
  role              String       @default("member")
  lastLoginAt       DateTime?
  passwordChangedAt DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  assignedSecurityFindings       SecurityFinding[]        @relation("SecurityFindingAssignee")
  riskAcceptedSecurityFindings   SecurityFinding[]        @relation("SecurityFindingRiskAccepter")
  createdRemediationPlans        RemediationPlan[]        @relation("RemediationPlanCreator")
  approvedRemediationPlans       RemediationPlan[]        @relation("RemediationPlanApprover")
  requestedApprovalRequests      ApprovalRequest[]        @relation("ApprovalRequestRequester")
  approvalDecisions              ApprovalRequest[]        @relation("ApprovalRequestApprover")
  requestedAutomationAssessments AutomationAssessment[]   @relation("AutomationAssessmentRequester")
  savedViews                     SavedView[]
  notifications                  Notification[]
  authSessions                   AuthSession[]
  passwordResetTokens            PasswordResetToken[]
  organizationMemberships        OrganizationMembership[]
  invitationsSent                Invitation[]

  @@unique([organizationId, email])
  @@index([organizationId])
}

model Organization {
  id                        String   @id @default(cuid())
  name                      String
  slug                      String   @unique
  onboardingState           String   @default("PENDING_INVITES")
  awsChangeExecutionEnabled Boolean  @default(false)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  users                 User[]
  teams                 Team[]
  awsAccounts           AwsAccount[]
  cloudResources        CloudResource[]
  relationships         ResourceRelationship[]
  securityFindings      SecurityFinding[]
  findingEvidenceSnapshots SecurityFindingEvidenceSnapshot[]
  costFindings          CostFinding[]
  complianceControls    ComplianceControl[]
  complianceEvidence    ComplianceEvidence[]
  recommendations       Recommendation[]
  riskAcceptances       RiskAcceptance[]
  scanRuns              ScanRun[]
  auditEvents           AuditEvent[]
  reportExports         ReportExport[]
  remediationPlans      RemediationPlan[]
  approvalRequests      ApprovalRequest[]
  automationAssessments AutomationAssessment[]
  automationEvents      AutomationEvent[]
  intelligenceSummaries IntelligenceSummary[]
  savedViews            SavedView[]
  securityAlertEvidence SecurityAlertEvidence[]
  notifications         Notification[]
  authSessions          AuthSession[]
  memberships           OrganizationMembership[]
  invitations           Invitation[]
  teamMemberships       TeamMembership[]
  securityMonitors      SecurityMonitor[]
  monitoringRuns        MonitoringRun[]
  securityAlerts        SecurityAlert[]
  monitoringSnapshots   MonitoringSnapshot[]
  settings              OrganizationSettings?
  onboarding            OrganizationOnboarding?
}

enum OrganizationMembershipStatus {
  ACTIVE
  REMOVED
}

model OrganizationMembership {
  id             String                       @id @default(cuid())
  organizationId String
  organization   Organization                 @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String                       @default("VIEWER")
  status         OrganizationMembershipStatus @default(ACTIVE)
  createdAt      DateTime                     @default(now())
  updatedAt      DateTime                     @updatedAt

  teamMemberships TeamMembership[]

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@index([organizationId, status])
}

model OrganizationSettings {
  id                String       @id @default(cuid())
  organizationId    String       @unique
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  dataMode          String       @default("development")
  sampleDataVisible Boolean      @default(false)
  allowedRegions    String[]     @default([])
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([organizationId])
}

model OrganizationOnboarding {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  state          String       @default("REGISTERED")
  checklist      Json         @default("{}")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
}

model Team {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  email          String?
  businessUnit   String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  archivedAt     DateTime?

  awsAccounts      AwsAccount[]
  cloudResources   CloudResource[]
  securityFindings SecurityFinding[]
  costFindings     CostFinding[]
  controls         ComplianceControl[]
  acceptances      RiskAcceptance[]
  memberships      TeamMembership[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model TeamMembership {
  id                       String                 @id @default(cuid())
  organizationId           String
  organization             Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  teamId                   String
  team                     Team                   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  organizationMembershipId String
  organizationMembership   OrganizationMembership @relation(fields: [organizationMembershipId], references: [id], onDelete: Cascade)
  isLead                   Boolean                @default(false)
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt
  archivedAt               DateTime?

  @@unique([teamId, organizationMembershipId])
  @@index([organizationId])
  @@index([teamId])
  @@index([organizationMembershipId])
}

model AwsAccount {
  id                             String              @id @default(cuid())
  organizationId                 String
  organization                   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name                           String
  accountId                      String
  environment                    Environment
  ownerTeamId                    String?
  ownerTeam                      Team?               @relation(fields: [ownerTeamId], references: [id], onDelete: SetNull)
  status                         AwsAccountStatus    @default(NOT_CONFIGURED)
  connectionStatus               AwsConnectionStatus @default(NOT_CONFIGURED)
  regions                        String[]
  lastScanAt                     DateTime?
  securityScore                  Int?
  costScore                      Int?
  complianceScore                Int?
  description                    String?
  roleArnPlaceholder             String?
  externalIdPlaceholder          String?
  businessUnit                   String?
  costCenter                     String?
  criticality                    AccountCriticality  @default(MEDIUM)
  organizationalUnit             String?
  setupInstructionsViewedAt      DateTime?
  changeExecutionEnabled         Boolean             @default(false)
  executionRoleArnPlaceholder    String?
  executionExternalIdPlaceholder String?
  archivedAt                     DateTime?
  createdAt                      DateTime            @default(now())
  updatedAt                      DateTime            @updatedAt

  resources           CloudResource[]
  securityFindings    SecurityFinding[]
  costFindings        CostFinding[]
  scanRuns            ScanRun[]
  securityMonitors    SecurityMonitor[]
  monitoringRuns      MonitoringRun[]
  securityAlerts      SecurityAlert[]
  monitoringSnapshots MonitoringSnapshot[]

  @@unique([organizationId, accountId])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, connectionStatus])
  @@index([organizationId, archivedAt])
}

model CloudResource {
  id                  String                   @id @default(cuid())
  organizationId      String
  organization        Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  awsAccountId        String
  awsAccount          AwsAccount               @relation(fields: [awsAccountId], references: [id], onDelete: Cascade)
  provider            String                   @default("aws")
  resourceType        String
  resourceId          String
  arn                 String?
  name                String?
  region              String?
  status              String?
  environment         Environment?
  ownerTeamId         String?
  ownerTeam           Team?                    @relation(fields: [ownerTeamId], references: [id], onDelete: SetNull)
  tags                Json                     @default("{}")
  metadata            Json                     @default("{}")
  source              DataSourceClassification @default(SAMPLE)
  riskCount           Int                      @default(0)
  costSignal          String?
  firstSeenAt         DateTime                 @default(now())
  lastSeenAt          DateTime?
  lastVerifiedAt      DateTime?
  staleAt             DateTime?
  archivedAt          DateTime?
  staleReason         String?
  successfulMissCount Int                      @default(0)
  lastScanRunId       String?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  sourceRelationships ResourceRelationship[] @relation("RelationshipSource")
  targetRelationships ResourceRelationship[] @relation("RelationshipTarget")
  securityFindings    SecurityFinding[]
  costFindings        CostFinding[]
  complianceEvidence  ComplianceEvidence[]
  remediationPlans    RemediationPlan[]
  securityAlerts      SecurityAlert[]
  evidenceSnapshots   SecurityFindingEvidenceSnapshot[]

  @@unique([organizationId, awsAccountId, resourceType, resourceId])
  @@index([organizationId])
  @@index([organizationId, resourceType])
  @@index([organizationId, awsAccountId])
  @@index([organizationId, source])
  @@index([organizationId, lastSeenAt])
  @@index([organizationId, region])
  @@index([organizationId, staleAt])
  @@index([organizationId, archivedAt])
  @@index([organizationId, lastScanRunId])
}

model ResourceRelationship {
  id                   String                   @id @default(cuid())
  organizationId       String
  organization         Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sourceResourceId     String
  sourceResource       CloudResource            @relation("RelationshipSource", fields: [sourceResourceId], references: [id], onDelete: Cascade)
  targetResourceId     String
  targetResource       CloudResource            @relation("RelationshipTarget", fields: [targetResourceId], references: [id], onDelete: Cascade)
  relationshipType     String
  evidence             Json                     @default("{}")
  sourceClassification DataSourceClassification @default(SYSTEM)
  firstSeenAt          DateTime                 @default(now())
  lastSeenAt           DateTime?
  staleAt              DateTime?
  lastScanRunId        String?
  createdAt            DateTime                 @default(now())

  @@unique([organizationId, sourceResourceId, targetResourceId, relationshipType])
  @@index([organizationId])
  @@index([organizationId, sourceResourceId])
  @@index([organizationId, targetResourceId])
  @@index([organizationId, sourceClassification])
  @@index([organizationId, staleAt])
  @@index([organizationId, lastScanRunId])
}

model SecurityFinding {
  id                   String                   @id @default(cuid())
  organizationId       String
  organization         Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  awsAccountId         String
  awsAccount           AwsAccount               @relation(fields: [awsAccountId], references: [id], onDelete: Cascade)
  resourceId           String?
  resource             CloudResource?           @relation(fields: [resourceId], references: [id], onDelete: SetNull)
  ruleId               String
  title                String
  description          String
  severity             FindingSeverity
  status               RiskStatus               @default(OPEN)
  workflowStatus       RiskStatus               @default(OPEN)
  evidence             Json                     @default("{}")
  source               DataSourceClassification @default(RULE_ENGINE)
  businessImpact       String?
  recommendation       String?
  complianceRefs       Json                     @default("[]")
  ownerTeamId          String?
  ownerTeam            Team?                    @relation(fields: [ownerTeamId], references: [id], onDelete: SetNull)
  assignedToUserId     String?
  assignedToUser       User?                    @relation("SecurityFindingAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  riskAcceptedUntil    DateTime?
  riskAcceptanceReason String?
  riskAcceptedByUserId String?
  riskAcceptedByUser   User?                    @relation("SecurityFindingRiskAccepter", fields: [riskAcceptedByUserId], references: [id], onDelete: SetNull)
  riskAcceptedAt       DateTime?
  remediationPlan      String?
  targetResolutionDate DateTime?
  priority             RiskPriority             @default(P2)
  lastWorkflowActionAt DateTime?
  archivedAt           DateTime?
  dueAt                DateTime?
  firstSeenAt          DateTime                 @default(now())
  lastSeenAt           DateTime                 @default(now())
  lastEvaluatedAt      DateTime?
  resolvedAt           DateTime?
  reopenedAt           DateTime?
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt

  recommendations  Recommendation[]
  riskAcceptances  RiskAcceptance[]
  remediationPlans RemediationPlan[]
  securityAlerts   SecurityAlert[]
  evidenceSnapshots SecurityFindingEvidenceSnapshot[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, workflowStatus])
  @@index([organizationId, priority])
  @@index([organizationId, assignedToUserId])
  @@index([organizationId, archivedAt])
  @@index([organizationId, severity])
  @@index([organizationId, source])
  @@index([organizationId, awsAccountId])
  @@index([organizationId, resourceId])
}

model SecurityFindingEvidenceSnapshot {
  id                   String                     @id @default(cuid())
  organizationId       String
  organization         Organization               @relation(fields: [organizationId], references: [id])
  securityFindingId    String
  securityFinding      SecurityFinding            @relation(fields: [securityFindingId], references: [id])
  resourceId           String?
  resource             CloudResource?             @relation(fields: [resourceId], references: [id])
  ruleId               String
  ruleVersion          String
  schemaVersion        Int                        @default(1)
  evaluationMode       String
  findingSource        DataSourceClassification
  resourceSource       DataSourceClassification?
  sampleData           Boolean
  title                String
  summary              String
  resourceSnapshot     Json
  evaluationContext    Json
  correlationId        String?
  capturedAt           DateTime
  createdAt            DateTime                   @default(now())
  riskAcceptances      RiskAcceptance[]

  @@index([organizationId, securityFindingId, capturedAt(sort: Desc), id(sort: Desc)])
}

model CostFinding {
  id                    String                   @id @default(cuid())
  organizationId        String
  organization          Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  awsAccountId          String
  awsAccount            AwsAccount               @relation(fields: [awsAccountId], references: [id], onDelete: Cascade)
  resourceId            String?
  resource              CloudResource?           @relation(fields: [resourceId], references: [id], onDelete: SetNull)
  ruleId                String
  title                 String
  description           String
  severity              FindingSeverity
  estimatedMonthlyWaste Decimal                  @default(0)
  estimatedAnnualWaste  Decimal                  @default(0)
  currency              String                   @default("USD")
  confidence            String
  evidence              Json                     @default("{}")
  source                DataSourceClassification @default(RULE_ENGINE)
  recommendation        String?
  status                RiskStatus               @default(OPEN)
  ownerTeamId           String?
  ownerTeam             Team?                    @relation(fields: [ownerTeamId], references: [id], onDelete: SetNull)
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  recommendations Recommendation[]
  riskAcceptances RiskAcceptance[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, severity])
  @@index([organizationId, source])
  @@index([organizationId, awsAccountId])
  @@index([organizationId, resourceId])
}

model ComplianceControl {
  id                 String           @id @default(cuid())
  organizationId     String
  organization       Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  controlId          String
  framework          String           @default("INTERNAL_GOVERNANCE")
  controlCode        String?
  controlTitle       String?
  controlDescription String?
  controlObjective   String?
  category           String?
  severity           FindingSeverity  @default(MEDIUM)
  group              String
  title              String
  description        String
  status             ComplianceStatus @default(WARNING)
  evidenceCount      Int              @default(0)
  findingCount       Int              @default(0)
  failedResources    Int              @default(0)
  lastScanAt         DateTime?
  lastEvaluatedAt    DateTime?
  ownerTeamId        String?
  ownerTeam          Team?            @relation(fields: [ownerTeamId], references: [id], onDelete: SetNull)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  evidence ComplianceEvidence[]

  @@unique([organizationId, controlId])
  @@index([organizationId])
  @@index([organizationId, status])
}

model ComplianceEvidence {
  id                   String                   @id @default(cuid())
  organizationId       String
  organization         Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  controlId            String
  control              ComplianceControl        @relation(fields: [controlId], references: [id], onDelete: Cascade)
  resourceId           String?
  resource             CloudResource?           @relation(fields: [resourceId], references: [id], onDelete: SetNull)
  status               ComplianceStatus
  evidence             Json                     @default("{}")
  evidenceType         String
  source               String                   @default("internal cloud governance evidence")
  sourceType           String                   @default("cloudshield_record")
  sourceId             String?
  summary              String?
  evidenceJson         Json                     @default("{}")
  sampleData           Boolean                  @default(true)
  sourceClassification DataSourceClassification @default(SAMPLE)
  confidence           String                   @default("medium")
  notes                String?
  collectedAt          DateTime                 @default(now())
  createdAt            DateTime                 @default(now())

  @@index([organizationId])
  @@index([organizationId, controlId])
  @@index([organizationId, sourceType])
  @@index([organizationId, sourceClassification])
}

model Recommendation {
  id                String                   @id @default(cuid())
  organizationId    String
  organization      Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  securityFindingId String?
  securityFinding   SecurityFinding?         @relation(fields: [securityFindingId], references: [id], onDelete: Cascade)
  costFindingId     String?
  costFinding       CostFinding?             @relation(fields: [costFindingId], references: [id], onDelete: Cascade)
  provider          String                   @default("aws")
  actionType        String
  title             String
  description       String
  riskReduction     String?
  terraformSnippet  String?
  cliSuggestion     String?
  manualSteps       Json                     @default("[]")
  blastRadius       String?
  rollbackNote      String?
  canExecute        Boolean                  @default(false)
  blockedReason     String                   @default("Automatic remediation is disabled in CloudShield v1.")
  source            DataSourceClassification @default(RULE_ENGINE)
  createdAt         DateTime                 @default(now())

  @@index([organizationId])
  @@index([organizationId, securityFindingId])
  @@index([organizationId, costFindingId])
  @@index([organizationId, source])
}

model RiskAcceptance {
  id                    String           @id @default(cuid())
  organizationId        String
  organization          Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  securityFindingId     String?
  securityFinding       SecurityFinding? @relation(fields: [securityFindingId], references: [id], onDelete: SetNull)
  costFindingId         String?
  costFinding           CostFinding?     @relation(fields: [costFindingId], references: [id], onDelete: Cascade)
  evidenceSnapshotId    String?
  evidenceSnapshot      SecurityFindingEvidenceSnapshot? @relation(fields: [evidenceSnapshotId], references: [id], onDelete: SetNull)
  businessJustification String
  approver              String
  owner                 String
  ownerTeamId           String?
  ownerTeam             Team?            @relation(fields: [ownerTeamId], references: [id], onDelete: SetNull)
  evidence              Json             @default("{}")
  expiresAt             DateTime
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  @@index([organizationId])
  @@index([organizationId, expiresAt])
  @@index([organizationId, evidenceSnapshotId])
}

model ScanRun {
  id                     String                   @id @default(cuid())
  organizationId         String
  organization           Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  awsAccountId           String?
  awsAccount             AwsAccount?              @relation(fields: [awsAccountId], references: [id], onDelete: SetNull)
  jobType                String
  status                 ScanRunStatus            @default(STARTED)
  phase                  String?
  startedAt              DateTime                 @default(now())
  completedAt            DateTime?
  errorCode              String?
  errorMessage           String?
  metadata               Json                     @default("{}")
  requestedByUserId      String?
  queueJobId             String?
  requestedRegions       String[]                 @default([])
  completedRegions       String[]                 @default([])
  failedRegions          Json                     @default("[]")
  scannerType            String?
  idempotencyKey         String?
  dedupeKey              String?
  queuedAt               DateTime?
  source                 DataSourceClassification @default(SYSTEM)
  connectorMode          String?
  scannerRoleReady       Boolean                  @default(false)
  resourceCount          Int                      @default(0)
  relationshipCount      Int                      @default(0)
  createdResourceCount   Int                      @default(0)
  updatedResourceCount   Int                      @default(0)
  unchangedResourceCount Int                      @default(0)
  staleResourceCount     Int                      @default(0)
  archivedResourceCount  Int                      @default(0)
  failureCount           Int                      @default(0)
  failureClassification  String?
  retryCount             Int                      @default(0)
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt

  @@unique([organizationId, idempotencyKey])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, awsAccountId])
  @@index([organizationId, source])
  @@index([organizationId, createdAt])
  @@index([organizationId, scannerType])
  @@index([organizationId, dedupeKey])
}

model AuditEvent {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actorUserId    String?
  action         String
  targetType     String
  targetId       String?
  metadata       Json         @default("{}")
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([organizationId, targetType, targetId])
  @@index([organizationId, action])
  @@index([organizationId, actorUserId])
  @@index([organizationId, createdAt])
}

model RemediationPlan {
  id                        String                        @id @default(cuid())
  organizationId            String
  organization              Organization                  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  findingId                 String
  finding                   SecurityFinding               @relation(fields: [findingId], references: [id], onDelete: Cascade)
  resourceId                String?
  resource                  CloudResource?                @relation(fields: [resourceId], references: [id], onDelete: SetNull)
  title                     String
  summary                   String
  riskLevel                 RemediationRiskLevel
  actionType                RemediationActionType
  implementationMode        RemediationImplementationMode
  recommendedSteps          Json                          @default("[]")
  rollbackPlan              Json                          @default("[]")
  approvalChecklist         Json                          @default("[]")
  riskImpactSummary         String?
  awsCliReview              String?
  terraformPatch            String?
  approvalStatus            RemediationApprovalStatus     @default(DRAFT)
  executionStatus           RemediationExecutionStatus    @default(EXECUTION_BLOCKED)
  executionMode             String                        @default("disabled")
  lifecycleState            String                        @default("RECOMMENDED")
  allowlistedOperation      String?
  confirmationTokenRequired String?
  requestedAction           Json                          @default("{}")
  normalizedPayload         Json                          @default("{}")
  preflightEvidence         Json                          @default("{}")
  beforeState               Json                          @default("{}")
  expectedAfterState        Json                          @default("{}")
  afterState                Json                          @default("{}")
  rollbackPayload           Json                          @default("{}")
  executionEvidence         Json                          @default("{}")
  blockedReason             String?
  failureClassification     String?
  idempotencyKey            String?
  awsRequestId              String?
  approvalExpiresAt         DateTime?
  simulatedAt               DateTime?
  queuedAt                  DateTime?
  executionStartedAt        DateTime?
  executionCompletedAt      DateTime?
  rollbackAvailableAt       DateTime?
  mutationOutcome           MutationOutcome?
  mutationAttemptedAt       DateTime?
  mutationConfirmedAt       DateTime?
  mutationProviderRequestId String?
  reconciliationStatus      MutationReconciliationStatus?
  reconciliationAttemptCount Int                         @default(0)
  lastReconciliationAt      DateTime?
  nextReconciliationAt      DateTime?
  manualReviewReason        String?
  executionLeaseStartedAt   DateTime?
  createdById               String
  createdBy                 User                          @relation("RemediationPlanCreator", fields: [createdById], references: [id], onDelete: Restrict)
  approvedById              String?
  approvedBy                User?                         @relation("RemediationPlanApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedByRequestId       String?                       @unique
  approvedByRequest         ApprovalRequest?              @relation("BoundApprovalRequest", fields: [approvedByRequestId], references: [id], onDelete: SetNull)
  createdAt                 DateTime                      @default(now())
  updatedAt                 DateTime                      @updatedAt

  approvalRequests ApprovalRequest[] @relation("PlanApprovalRequests")

  @@unique([organizationId, idempotencyKey])
  @@index([organizationId])
  @@index([organizationId, findingId])
  @@index([organizationId, approvalStatus])
  @@index([organizationId, executionStatus])
  @@index([organizationId, lifecycleState])
  @@index([mutationOutcome, mutationAttemptedAt])
  @@index([reconciliationStatus, nextReconciliationAt])
}

model ApprovalRequest {
  id                String                @id @default(cuid())
  organizationId    String
  organization      Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  remediationPlanId String
  remediationPlan   RemediationPlan       @relation("PlanApprovalRequests", fields: [remediationPlanId], references: [id], onDelete: Cascade)
  authorizedPlan    RemediationPlan?      @relation("BoundApprovalRequest")
  requestedById     String
  requestedBy       User                  @relation("ApprovalRequestRequester", fields: [requestedById], references: [id], onDelete: Restrict)
  approvedById      String?
  approvedBy        User?                 @relation("ApprovalRequestApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  status            ApprovalRequestStatus @default(PENDING)
  decisionReason    String?
  expectedImpact    String?
  confirmationToken String?
  evidenceSnapshot  Json                  @default("{}")
  payloadHash       String?
  resourceStateFingerprint              String?
  resourceStateFingerprintSchemaVersion Int?
  resourceStateFingerprintPolicyVersion String?
  resourceStateCapturedAt               DateTime?
  resourceStateEvidence                 Json?
  expiresAt         DateTime?
  createdAt         DateTime              @default(now())
  decidedAt         DateTime?

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, remediationPlanId])
}

model ReportExport {
  id                       String             @id @default(cuid())
  organizationId           String
  organization             Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  reportType               String
  reportScope              String             @default("organization")
  title                    String?
  status                   ReportExportStatus @default(QUEUED)
  format                   String             @default("json")
  summaryJson              Json               @default("{}")
  filtersJson              Json               @default("{}")
  filters                  Json               @default("{}")
  sampleData               Boolean            @default(true)
  officialAuditReportClaim Boolean            @default(false)
  requestedByUserId        String?
  generatedByUserId        String?
  generatedAt              DateTime?
  exportUrl                String?
  exportedFilePath         String?
  requestedBy              String?
  createdAt                DateTime           @default(now())
  completedAt              DateTime?
  archivedAt               DateTime?

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, reportType])
  @@index([organizationId, archivedAt])
}

model AutomationAssessment {
  id             String                     @id @default(cuid())
  organizationId String
  organization   Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  requestedById  String
  requestedBy    User                       @relation("AutomationAssessmentRequester", fields: [requestedById], references: [id], onDelete: Restrict)
  status         AutomationAssessmentStatus @default(CREATED)
  mode           AutomationAssessmentMode   @default(EVALUATION)
  summary        Json                       @default("{}")
  safetyFlags    Json                       @default("{}")
  startedAt      DateTime                   @default(now())
  completedAt    DateTime?
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt

  events              AutomationEvent[]
  intelligenceSummary IntelligenceSummary?

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, createdAt])
}

model AutomationEvent {
  id             String               @id @default(cuid())
  organizationId String
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assessmentId   String
  assessment     AutomationAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  type           String
  status         String
  message        String
  metadata       Json                 @default("{}")
  createdAt      DateTime             @default(now())

  @@index([organizationId])
  @@index([organizationId, assessmentId])
  @@index([organizationId, type])
}

model IntelligenceSummary {
  id                     String               @id @default(cuid())
  organizationId         String
  organization           Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assessmentId           String               @unique
  assessment             AutomationAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  executiveSummary       String
  topRisks               Json                 @default("[]")
  costOpportunities      Json                 @default("[]")
  complianceGaps         Json                 @default("[]")
  remediationPlanSummary Json                 @default("[]")
  nextActions            Json                 @default("[]")
  safetyNotes            Json                 @default("{}")
  createdAt              DateTime             @default(now())

  @@index([organizationId])
  @@index([organizationId, createdAt])
}

model SavedView {
  id             String             @id @default(cuid())
  organizationId String
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace      SavedViewWorkspace
  name           String
  filters        Json               @default("{}")
  sort           Json               @default("{}")
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@unique([organizationId, userId, workspace, name])
  @@index([organizationId, workspace])
  @@index([organizationId, userId])
}

model Notification {
  id             String                   @id @default(cuid())
  organizationId String
  organization   Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String?
  user           User?                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamId         String?
  severity       NotificationSeverity     @default(INFO)
  source         DataSourceClassification @default(SYSTEM)
  type           String
  title          String
  message        String
  targetType     String?
  targetId       String?
  dedupeKey      String?
  readAt         DateTime?
  createdAt      DateTime                 @default(now())

  @@unique([organizationId, dedupeKey])
  @@index([organizationId, userId, readAt])
  @@index([organizationId, teamId, readAt])
  @@index([organizationId, type])
  @@index([organizationId, createdAt])
}

model AuthSession {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tokenHash      String       @unique
  userAgent      String?
  ipAddress      String?
  expiresAt      DateTime
  revokedAt      DateTime?
  lastUsedAt     DateTime     @default(now())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([userId])
  @@index([organizationId])
  @@index([tokenHash])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([tokenHash])
}

model Invitation {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           String       @default("VIEWER")
  tokenHash      String       @unique
  acceptedAt     DateTime?
  revokedAt      DateTime?
  expiresAt      DateTime
  sendCount      Int          @default(1)
  lastSentAt     DateTime     @default(now())
  inviterId      String
  inviter        User         @relation(fields: [inviterId], references: [id], onDelete: Restrict)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, email])
  @@index([organizationId])
  @@index([email])
  @@index([tokenHash])
}

enum SecurityMonitorCategory {
  ACCOUNT_HEALTH
  INVENTORY_FRESHNESS
  SECURITY_FINDING
  RESOURCE_DRIFT
  PUBLIC_EXPOSURE
  ENCRYPTION
  IDENTITY_AND_ACCESS
  COMPLIANCE
  TAGGING
  COST_SECURITY_SIGNAL
}

enum SecurityMonitorStatus {
  ACTIVE
  DISABLED
  ERROR
}

enum MonitoringRunStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

enum SecurityAlertStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

model SecurityMonitor {
  id              String                   @id @default(cuid())
  organizationId  String
  organization    Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  awsAccountId    String?
  awsAccount      AwsAccount?              @relation(fields: [awsAccountId], references: [id], onDelete: Cascade)
  name            String
  description     String
  category        SecurityMonitorCategory
  severity        FindingSeverity          @default(MEDIUM)
  status          SecurityMonitorStatus    @default(ACTIVE)
  scopeType       String                   @default("ORGANIZATION")
  resourceScope   String?
  ruleKey         String
  configuration   Json                     @default("{}")
  enabled         Boolean                  @default(true)
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  alerts          SecurityAlert[]

  @@unique([organizationId, ruleKey, awsAccountId])
  @@index([organizationId])
  @@index([organizationId, ruleKey])
}

model MonitoringRun {
  id                           String                   @id @default(cuid())
  organizationId               String
  organization                 Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  awsAccountId                 String?
  awsAccount                   AwsAccount?              @relation(fields: [awsAccountId], references: [id], onDelete: Cascade)
  status                       MonitoringRunStatus      @default(RUNNING)
  trigger                      String                   @default("MANUAL")

  awsApiCallExecuted           Boolean                  @default(false)
  scannerRun                   Boolean                  @default(false)
  mutationExecuted             Boolean                  @default(false)
  terraformApplyExecuted       Boolean                  @default(false)
  automaticRemediationExecuted Boolean                  @default(false)
  remediationExecuted          Boolean                  @default(false)

  evaluatedCount               Int                      @default(0)
  alertsCreated                Int                      @default(0)
  alertsUpdated                Int                      @default(0)
  alertsResolved               Int                      @default(0)

  errorCode                    String?
  errorSummary                 Json                     @default("{}")

  startedAt                    DateTime                 @default(now())
  completedAt                  DateTime?

  securityAlertEvidence SecurityAlertEvidence[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, startedAt])
}

model SecurityAlert {
  id                String                   @id @default(cuid())
  organizationId    String
  organization      Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  awsAccountId      String?
  awsAccount        AwsAccount?              @relation(fields: [awsAccountId], references: [id], onDelete: Cascade)
  cloudResourceId   String?
  cloudResource     CloudResource?           @relation(fields: [cloudResourceId], references: [id], onDelete: SetNull)
  securityFindingId String?
  securityFinding   SecurityFinding?         @relation(fields: [securityFindingId], references: [id], onDelete: SetNull)
  monitorId         String?
  monitor           SecurityMonitor?         @relation(fields: [monitorId], references: [id], onDelete: SetNull)

  dedupeKey         String
  title             String
  description       String
  severity          FindingSeverity
  status            SecurityAlertStatus      @default(OPEN)
  category          SecurityMonitorCategory

  firstObservedAt   DateTime                 @default(now())
  lastObservedAt    DateTime                 @default(now())
  resolvedAt        DateTime?

  evidence          Json                     @default("{}")
  evidenceCount     Int                      @default(0)
  mappedEvidence    Json                     @default("[]")
  sourceType        String?
  sourceId          String?

  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  securityAlertEvidence SecurityAlertEvidence[]

  @@unique([organizationId, dedupeKey])
  @@index([organizationId])
  @@index([organizationId, status, severity, updatedAt])
  @@index([organizationId, awsAccountId, status])
  @@index([organizationId, category, status])
}

model MonitoringSnapshot {
  id                           String                   @id @default(cuid())
  organizationId               String
  organization                 Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  awsAccountId                 String?
  awsAccount                   AwsAccount?              @relation(fields: [awsAccountId], references: [id], onDelete: Cascade)
  monitoringRunId              String?
  generatedAt                  DateTime                 @default(now())

  postureSummary               Json                     @default("{}")
  accountState                 Json                     @default("{}")
  findingFingerprints          Json                     @default("{}")
  complianceStates             Json                     @default("{}")

  deterministicChecksum        String
  schemaVersion                Int                      @default(1)

  @@index([organizationId])
  @@index([organizationId, generatedAt])
  @@index([organizationId, awsAccountId])
}

model SecurityAlertEvidence {
  id              String         @id @default(cuid())
  organizationId  String
  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  securityAlertId String
  securityAlert   SecurityAlert  @relation(fields: [securityAlertId], references: [id], onDelete: Restrict)
  monitoringRunId String?
  monitoringRun   MonitoringRun? @relation(fields: [monitoringRunId], references: [id], onDelete: SetNull)

  evidenceType  String
  sourceType    String
  sourceId      String?
  title         String
  summary       String
  observedAt    DateTime
  createdAt     DateTime @default(now())
  correlationId String?
  dedupeKey     String
  schemaVersion Int      @default(1)

  @@unique([organizationId, dedupeKey])
  @@index([organizationId, securityAlertId, observedAt(sort: Desc), id(sort: Desc)])
  @@index([organizationId, monitoringRunId])
  @@index([organizationId, createdAt])
}
