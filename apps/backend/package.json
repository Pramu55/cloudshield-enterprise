{
  "name": "@cloudshield/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm run build && node --test \"dist/**/*.test.js\""
  },
  "dependencies": {
    "@aws-sdk/client-ec2": "^3.1058.0",
    "@aws-sdk/client-sts": "^3.940.0",
    "@cloudshield/config": "workspace:*",
    "@cloudshield/contracts": "workspace:*",
    "@cloudshield/database": "workspace:*",
    "@cloudshield/logger": "workspace:*",
    "@cloudshield/security": "workspace:*",
    "@cloudshield/utils": "workspace:*",
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^13.0.1",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.34.2",
    "fastify": "^5.2.1",
    "zod": "^4.1.0"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
