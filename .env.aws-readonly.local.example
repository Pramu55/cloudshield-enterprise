# CloudShield locked local runtime protocol example.
# Copy this file to .env.aws-readonly.local and fill values locally.
# Do not commit .env.aws-readonly.local. Do not paste secret values into chat.

# Local runtime mode: STS validation may be available, but inventory and changes stay disabled.
AWS_CONNECTOR_MODE=sts-validation
AWS_INVENTORY_SCANNER_MODE=disabled
AWS_CHANGE_EXECUTION_MODE=disabled

# Approved sandbox scope. Use non-secret allowlist values only.
AWS_REGION_DEFAULT=ap-south-1
AWS_ALLOWED_ACCOUNT_IDS=123456789012
AWS_ALLOWED_REGIONS=ap-south-1

# Scanner role configuration. Values are required locally but are intentionally placeholders here.
AWS_ROLE_ARN=arn:aws:iam::123456789012:role/CloudShieldReadOnlyScannerRole
AWS_EXTERNAL_ID=replace-with-local-external-id

# Bootstrap profile mount. Use an absolute local path that contains AWS config/credentials files.
AWS_PROFILE=cloudshield-readonly
AWS_SHARED_CONFIG_DIR=C:\Users\your-user\.aws

# Executor role must remain empty for locked local runtime.
AWS_EXECUTOR_ROLE_ARN=
AWS_EXECUTOR_EXTERNAL_ID=
