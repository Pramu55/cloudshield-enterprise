# CloudShield Enterprise local development example.
# Copy to .env for local use. Do not commit real credentials or secrets.

NODE_ENV=development
PORT=4000
API_BASE_URL=http://localhost:4100
NEXT_PUBLIC_API_BASE_URL=http://localhost:4100

DATABASE_URL=postgresql://cloudshield:cloudshield_local_password@localhost:55432/cloudshield
REDIS_HOST=localhost
REDIS_PORT=6381

# Local development only. Replace for any non-local environment.
JWT_SECRET=cloudshield-local-demo-jwt-secret-change-me

# CloudShield AWS sandbox validation. Keep disabled unless explicitly authorized.
AWS_CONNECTOR_MODE=disabled
AWS_INVENTORY_SCANNER_MODE=disabled
AWS_REGION_DEFAULT=us-east-1

# Scanner role: STS validation and read-only EC2 inventory only.
AWS_ROLE_ARN=
AWS_EXTERNAL_ID=

# Executor role: governed EC2 governance tagging pilot only.
AWS_EXECUTOR_ROLE_ARN=
AWS_EXECUTOR_EXTERNAL_ID=
AWS_CHANGE_EXECUTION_MODE=disabled

# Sandbox allow controls. Comma-separated, no secrets.
AWS_ALLOWED_ACCOUNT_IDS=
AWS_ALLOWED_REGIONS=us-east-1
CLOUDSHIELD_ALLOWED_GOVERNANCE_TAG_KEYS=CloudShieldManaged,CloudShieldOwner,CloudShieldEnvironment,CloudShieldReviewDate

LOG_LEVEL=info
MONITORING_ENABLED=false
BACKUP_RETENTION_DAYS=7
