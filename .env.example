# CloudShield Enterprise local development example.
# Copy to .env for local use. Do not commit real credentials or secrets.

NODE_ENV=development
PORT=4000
API_BASE_URL=http://localhost:4100
NEXT_PUBLIC_API_BASE_URL=http://localhost:4100

DATABASE_URL=postgresql://cloudshield:cloudshield_local_password@localhost:55432/cloudshield
REDIS_HOST=localhost
REDIS_PORT=6381

# CloudShield v1 is read-only. No AWS credentials are required for the foundation milestone.
